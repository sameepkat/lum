use io
use array

X = [[1, 2, 3], [4, 5, 6]]

rows = len(X)
columns = len(X[0])

T = []
c = 0
while c < columns {
    row = []
    r = 0
    while r < rows {
        push(row, 0)
        r = r + 1
    }
    push(T, row)
    c = c + 1
}

r = 0
while r < rows {
    c = 0
    while c < columns {
        T[c][r] = X[r][c]
        c = c + 1
    }
    r = r + 1
}

println("Original:")
println(X)

println("Transposed:")
println(T)