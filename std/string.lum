
fn string(val){
   return __to_string(val)
}

fn number(val){
   return __to_number(val)
}

fn ord(val){
   return __to_ord(val)
}

fn chr(val){
   return __to_chr(val)
}

fn substr(str, start, len){
   return __substr(str, start, len)
}

fn split(str, delimiter){
   return __split(str, delimiter)
}

fn join(arr, delimiter){
   return __join(arr, delimiter) 
}

fn index_of(str, sub){
   return __index_of(str, sub)
}