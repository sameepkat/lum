fn contains(arr, element){
   i = 0
   while i < len(arr) {
     if(arr[i] == element){
       return true
      }
      i = i + 1
    }
    return false
}

fn concat(arr1, arr2){
   arr = []
   i = 0
   while i < len(arr1){
     push(arr, arr1[i])
     i = i + 1
   }
   i = 0
   while i < len(arr2){
     push(arr, arr2[i])
     i = i + 1
   }

   return arr
}